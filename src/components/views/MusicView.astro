---
import { getCollection, render } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { localizedEntries, type Locale } from "@/i18n";
import { t } from "@/i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);

const all = await getCollection("music", ({ data }) => !data.draft);
// reverse-chron by most recent activity: ongoing (start, no end) first,
// then by end year, then start; undated (timeless/solo) last
const key = (d: (typeof all)[number]["data"]) =>
  d.start && !d.end ? 9999 : (d.end ?? d.start ?? 0);
const projects = localizedEntries(all, lang).sort(
  (a, b) =>
    key(b.entry.data) - key(a.entry.data) ||
    (b.entry.data.start ?? 0) - (a.entry.data.start ?? 0),
);

const rendered = await Promise.all(
  projects.map(async ({ slug, entry }) => {
    const hasBody = entry.body && entry.body.trim().length > 0;
    const { Content } = await render(entry);
    return { slug, entry, Content, hasBody };
  }),
);

const genresOf = (g?: string) =>
  g ? g.split("·").map((x) => x.trim()).filter(Boolean) : [];

type MusicData = (typeof all)[number]["data"];
const tagsFor = (d: MusicData) =>
  genresOf(d.genre).map((x) => x.toLowerCase()).join(",");

const years = (d: MusicData) =>
  d.start
    ? d.end && d.end !== d.start
      ? `${d.start}–${d.end}`
      : d.end
        ? String(d.start)
        : `${d.start} → ${tr("music.present")}`
    : "";

const firstYear = Math.min(...all.map((e) => e.data.start ?? 9999));
---

<SiteLayout lang={lang} title={tr("music.title")} description={tr("music.metaDesc")}>
  <section class="hero container">
    <div class="eyebrow mono">{tr("music.title")} · {firstYear} → {new Date().getFullYear()}</div>
    <h1>{tr("music.title")}<em>.</em></h1>
    <p class="lede">{tr("music.metaDesc")}</p>
    <p class="hint mono">{tr("music.hint")}</p>
  </section>

  <div id="filterbar" class="container mono idle">
    <span class="active-tag"></span><span id="count"></span>
    <button id="clear">{tr("work.clear")}</button>
  </div>

  <div
    class="ledger container"
    data-word-one={tr("work.project")}
    data-word-many={tr("work.projects.short")}
  >
    {
      rendered.map(({ entry: { data }, Content, hasBody }) => (
        <div class:list={["row", data.featured && "open"]} data-entry data-tags={tagsFor(data)}>
          <div class="row-header" role="button" tabindex="0" aria-expanded={data.featured ? "true" : "false"}>
            <span class="year mono">{years(data) || "····"}</span>
            <span class="name">{data.title}</span>
            <span class="rowtags mono">
              {genresOf(data.genre).map((g) => (
                <button class="minitag tag" data-tag={g.toLowerCase()}>{g}</button>
              ))}
            </span>
            <span class="chevron mono" aria-hidden="true">+</span>
          </div>
          <div class="row-detail">
            {data.summary && <p class="detail-summary">{data.summary}</p>}
            {data.aka && <p class="aka mono">{data.aka}</p>}
            <div class="meta mono">
              {data.role && <span>{data.role.toUpperCase()}</span>}
              {data.links.map((l) => (
                <span>
                  {" · "}
                  <a href={l.url} target="_blank" rel="noopener noreferrer">
                    {l.label.toUpperCase()} ↗
                  </a>
                </span>
              ))}
            </div>
            {hasBody && (
              <div class="detail-prose">
                <Content />
              </div>
            )}
            {data.bandcampAlbums.length > 0 && (
              <div class="players">
                {data.bandcampAlbums.map((a) => (
                  <iframe
                    style="border: 0; width: 100%; height: 120px;"
                    src={`https://bandcamp.com/EmbeddedPlayer/album=${a.id}/size=large/bgcol=151520/linkcol=fd5b17/tracklist=false/artwork=small/transparent=true/`}
                    seamless
                    loading="lazy"
                    title={`${data.title} — ${a.title}`}
                  />
                ))}
              </div>
            )}
            {data.soundcloudPlaylist && (
              <div class="players">
                <iframe
                  width="100%"
                  height="300"
                  scrolling="no"
                  frameborder="no"
                  loading="lazy"
                  title={`${data.title} on SoundCloud`}
                  src={`https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/playlists/${data.soundcloudPlaylist}&color=%23fd5b17&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&visual=false`}
                />
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>
</SiteLayout>

<style>
  .mono { font-family: var(--font-mono); }
  .hero { padding: 64px 24px 24px; }
  .eyebrow {
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  h1 {
    font-size: clamp(2.4rem, 6vw, 4.25rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 12px 0 16px;
  }
  h1 em { font-style: normal; color: var(--primary); }
  .lede { color: var(--muted); max-width: 52ch; font-size: 1.1rem; }
  .hint {
    color: var(--dim);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    max-width: 60ch;
    margin-top: 18px;
  }

  /* filter bar (mirrors /work/) */
  #filterbar {
    padding-top: 8px;
    padding-bottom: 8px;
    font-size: 11.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    min-height: 28px;
    display: flex;
    gap: 16px;
    align-items: center;
  }
  #filterbar .active-tag {
    color: var(--bg);
    background: var(--primary);
    border-radius: 3px;
    padding: 2px 8px;
  }
  #filterbar #clear {
    cursor: pointer;
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 3px;
    font: inherit;
    padding: 2px 8px;
    letter-spacing: inherit;
    text-transform: inherit;
  }
  #filterbar #clear:hover { color: var(--primary); border-color: var(--primary); }
  #filterbar.idle .active-tag,
  #filterbar.idle #count,
  #filterbar.idle #clear { display: none; }

  .ledger { padding-top: 8px; padding-bottom: 96px; }
  .row { border-top: 1px solid var(--border-soft); }
  .row.hide { display: none; }
  .row-header {
    display: grid;
    grid-template-columns: 118px 1fr auto;
    align-items: baseline;
    gap: 0 24px;
    padding: 14px 0;
    cursor: pointer;
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    color: inherit;
    font: inherit;
  }
  .row-header:hover .name { color: var(--primary); }
  .year { font-size: 13.5px; color: var(--dim); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .name { font-weight: 400; font-size: 1.1rem; letter-spacing: 0.02em; text-transform: uppercase; }
  .rowtags { display: flex; gap: 10px; flex-wrap: wrap; grid-column: 2; margin-top: 4px; }
  .minitag {
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    white-space: nowrap;
    border-bottom: 1px dotted transparent;
  }
  .minitag:hover, .minitag.on { border-bottom-color: var(--primary); }
  .chevron {
    color: var(--dim);
    font-size: 15px;
    align-self: center;
    transition: transform var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .row-header:hover .chevron { color: var(--primary); }
  .row.open .chevron { transform: rotate(45deg); }

  .row-detail {
    display: none;
    padding: 0 0 26px 142px;
    max-width: 700px;
  }
  .row.open .row-detail { display: block; }
  .detail-summary { color: var(--muted); font-size: 0.98rem; line-height: 1.6; }
  .aka { color: var(--dim); font-size: 11px; letter-spacing: 0.04em; margin-top: 8px; }
  .meta { font-size: 11px; color: var(--dim); letter-spacing: 0.08em; margin-top: 10px; }
  .meta a { color: inherit; border-bottom: 1px dotted var(--dim); }
  .meta a:hover { color: var(--primary); border-bottom-color: var(--primary); text-decoration: none; }
  .detail-prose { margin-top: 12px; }
  .detail-prose :global(p) { font-size: 0.98rem; line-height: 1.65; margin-bottom: 1em; color: var(--text); }
  .detail-prose :global(strong) { color: var(--text); font-weight: 600; }
  .players { display: flex; flex-direction: column; gap: 10px; margin-top: 18px; max-width: 560px; }

  @media (max-width: 640px) {
    .row-header { grid-template-columns: 1fr auto; }
    .year { grid-column: 1; color: var(--primary); }
    .rowtags { grid-column: 1; }
    .row-detail { padding-left: 0; }
  }
</style>

<script>
  const bar = document.getElementById("filterbar")!;
  const activeEl = bar.querySelector(".active-tag")!;
  const countEl = document.getElementById("count")!;
  const ledger = document.querySelector<HTMLElement>(".ledger")!;
  let active: string | null = null;

  function applyFilter(tag: string | null) {
    active = tag;
    let shown = 0;
    document.querySelectorAll<HTMLElement>("[data-entry]").forEach((e) => {
      const hit = !tag || (e.dataset.tags ?? "").split(",").includes(tag);
      e.classList.toggle("hide", !hit);
      if (hit) shown++;
    });
    document
      .querySelectorAll<HTMLElement>(".tag")
      .forEach((t) => t.classList.toggle("on", !!tag && t.dataset.tag === tag));
    bar.classList.toggle("idle", !tag);
    if (tag) {
      activeEl.textContent = tag;
      countEl.textContent = `${shown} ${
        shown === 1 ? ledger.dataset.wordOne : ledger.dataset.wordMany
      }`;
      history.replaceState(null, "", "#" + encodeURIComponent(tag));
    } else {
      history.replaceState(null, "", location.pathname);
    }
  }

  document.addEventListener("click", (e) => {
    const el = e.target as HTMLElement;
    const t = el.closest<HTMLElement>(".tag");
    if (t && t.dataset.tag) {
      applyFilter(active === t.dataset.tag ? null : t.dataset.tag);
      return;
    }
    const header = el.closest<HTMLElement>(".row-header");
    if (header) {
      const row = header.closest<HTMLElement>(".row")!;
      const open = row.classList.toggle("open");
      header.setAttribute("aria-expanded", String(open));
    }
  });
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Enter" && e.key !== " ") return;
    const header = (e.target as HTMLElement).closest<HTMLElement>(".row-header");
    if (!header) return;
    e.preventDefault();
    const row = header.closest<HTMLElement>(".row")!;
    const open = row.classList.toggle("open");
    header.setAttribute("aria-expanded", String(open));
  });
  document.getElementById("clear")!.addEventListener("click", () => applyFilter(null));
  if (location.hash) applyFilter(decodeURIComponent(location.hash.slice(1)));
</script>
