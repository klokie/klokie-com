---
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { localizedEntries, localizeUrl, type Locale } from "@/i18n";
import { t } from "@/i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);

const all = await getCollection("cases", ({ data }) => data.featured && !data.draft);
const featured = localizedEntries(all, lang)
  .sort(
    (a, b) =>
      (b.entry.data.date?.getTime() ?? 0) - (a.entry.data.date?.getTime() ?? 0),
  )
  .slice(0, 6);
---

<SiteLayout lang={lang}>
  <section class="hero container">
    <div class="eyebrow mono">{tr("home.eyebrow")}</div>
    <h1>Daniel “Klokie”<br />Grossfeld<em>.</em></h1>
    <p class="lede">{tr("home.lede")}</p>
  </section>

  <section class="container featured">
    <h2 class="mono">{tr("home.featured")}</h2>
    <ul>
      {
        featured.map(({ slug, entry: { data } }) => (
          <li>
            <a href={localizeUrl(`/work/${slug}/`, lang)}>
              <span class="name">{data.title}</span>
              <span class="meta mono">
                {data.categories[0]}
                {data.date && ` · ${data.date.getFullYear()}`}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
    <div class="ctas">
      <a href={localizeUrl("/work/", lang)}>{tr("home.allWork")}</a>
      <a href={localizeUrl("/contact/", lang)}>{tr("home.contact")}</a>
    </div>
  </section>
</SiteLayout>

<style>
  .mono { font-family: var(--font-mono); }
  .hero { padding: 80px 24px 40px; }
  .eyebrow {
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  h1 {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 12px 0 18px;
  }
  h1 em { font-style: normal; color: var(--primary); }
  .lede { color: var(--muted); max-width: 52ch; font-size: 1.15rem; }

  .featured { padding-bottom: 96px; }
  .featured h2 {
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
    margin-bottom: 8px;
  }
  .featured ul { list-style: none; margin: 0; padding: 0; }
  .featured li { border-bottom: 1px dotted var(--border-soft); }
  .featured a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0;
    color: var(--text);
  }
  .featured a:hover { text-decoration: none; }
  .featured a:hover .name { color: var(--primary); }
  .featured .name { font-size: 1.25rem; font-weight: 400; }
  .featured .meta { font-size: 11px; color: var(--dim); letter-spacing: 0.08em; white-space: nowrap; }
  .ctas { display: flex; gap: 32px; margin-top: 24px; }
  .ctas a { font-size: 0.95rem; }
</style>
