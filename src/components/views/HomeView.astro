---
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { localizedEntries, localizeUrl, dateLocale, type Locale } from "@/i18n";
import { t } from "@/i18n/ui";
import { siteConfig } from "@/site/config";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);

const allCases = await getCollection("cases", ({ data }) => data.featured && !data.draft);
const featured = localizedEntries(allCases, lang)
  .sort(
    (a, b) =>
      (b.entry.data.date?.getTime() ?? 0) - (a.entry.data.date?.getTime() ?? 0),
  )
  .slice(0, 6);

const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const articles = localizedEntries(allArticles, lang)
  .sort((a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime())
  .slice(0, 4);
const fmt = new Intl.DateTimeFormat(dateLocale[lang], { year: "numeric", month: "short" });

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Daniel Grossfeld",
  alternateName: "Klokie",
  jobTitle: "Senior Web Architect",
  url: siteConfig.url,
  image: new URL("/media/klokie.jpg", siteConfig.url).href,
  address: { "@type": "PostalAddress", addressLocality: "Stockholm", addressCountry: "SE" },
  sameAs: Object.values(siteConfig.social),
};
---

<SiteLayout lang={lang} jsonLd={personJsonLd} ogType="profile">
  <section class="hero">
    <div class="hero-inner container">
      <div class="hero-text">
        <div class="eyebrow mono">{tr("home.eyebrow")}</div>
        <h1>Daniel “Klokie”<br />Grossfeld<em>.</em></h1>
        <p class="lede">{tr("home.lede")}</p>
      </div>
      <img
        class="portrait"
        src="/media/klokie.jpg"
        alt="Daniel “Klokie” Grossfeld"
        width="200"
        height="200"
        loading="eager"
      />
    </div>
  </section>

  <section class="container cols">
    <div class="col">
      <h2 class="mono">{tr("nav.articles")}</h2>
      <ul>
        {
          articles.map(({ slug, entry: { data } }) => (
            <li>
              <a href={localizeUrl(`/articles/${slug}/`, lang)}>
                <span class="name">{data.title}</span>
                <span class="meta mono">{fmt.format(data.date)}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <div class="ctas">
        <a href={localizeUrl("/articles/", lang)}>→ {tr("nav.articles")}</a>
      </div>
    </div>

    <div class="col">
      <h2 class="mono">{tr("home.featured")}</h2>
      <ul>
        {
          featured.map(({ slug, entry: { data } }) => (
            <li>
              <a href={localizeUrl(`/work/${slug}/`, lang)}>
                <span class="name work-name">{data.title}</span>
                <span class="meta mono">
                  {data.categories[0]}
                  {data.date && ` · ${data.date.getFullYear()}`}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <div class="ctas">
        <a href={localizeUrl("/work/", lang)}>{tr("home.allWork")}</a>
        <a href={localizeUrl("/contact/", lang)}>{tr("home.contact")}</a>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .mono { font-family: var(--font-mono); }

  .hero {
    position: relative;
    background:
      linear-gradient(
        to bottom,
        color-mix(in srgb, var(--bg) 45%, transparent) 0%,
        color-mix(in srgb, var(--bg) 72%, transparent) 60%,
        var(--bg) 100%
      ),
      url("/media/hero-bg.svg") center / cover no-repeat;
  }
  .hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    padding-top: 56px;
    padding-bottom: 40px;
  }
  .eyebrow {
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin: 12px 0 18px;
  }
  h1 em { font-style: normal; color: var(--primary); }
  .lede { color: var(--muted); max-width: 46ch; font-size: 1.15rem; }
  .portrait {
    flex: none;
    width: 200px;
    height: 200px;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--text) 25%, transparent);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--bg) 60%, transparent);
  }

  .cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    padding-top: 36px;
    padding-bottom: 48px;
  }
  .col h2 {
    font-size: 11.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
    margin-bottom: 8px;
  }
  .col ul { list-style: none; margin: 0; padding: 0; }
  .col li { border-bottom: 1px dotted var(--border-soft); }
  .col a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 11px 0;
    color: var(--text);
  }
  .col a:hover { text-decoration: none; }
  .col a:hover .name { color: var(--primary); }
  .name { font-size: 1.05rem; font-weight: 400; }
  .work-name { text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.98rem; }
  .meta { font-size: 11px; color: var(--dim); letter-spacing: 0.08em; white-space: nowrap; }
  .ctas { display: flex; gap: 28px; margin-top: 20px; }
  .ctas a { font-size: 0.92rem; }

  @media (max-width: 720px) {
    .hero-inner { flex-direction: column-reverse; align-items: flex-start; gap: 24px; }
    .portrait { width: 128px; height: 128px; }
    .cols { grid-template-columns: 1fr; gap: 48px; }
  }
</style>
