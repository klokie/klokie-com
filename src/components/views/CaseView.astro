---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { localizeUrl, type Locale } from "@/i18n";
import { t } from "@/i18n/ui";

interface Props {
  lang: Locale;
  entry: CollectionEntry<"cases">;
}
const { lang, entry } = Astro.props;
const tr = t(lang);
const { data } = entry;
const { Content } = await render(entry);

const years = data.date
  ? data.endDate && data.endDate.getFullYear() !== data.date.getFullYear()
    ? `${data.date.getFullYear()}–${data.endDate.getFullYear()}`
    : String(data.date.getFullYear())
  : "";
---

<SiteLayout lang={lang} title={data.title} description={data.summary} ogImage={data.image}>
  <article class="container">
    <a class="back mono" href={localizeUrl("/work/", lang)}>{tr("work.back")}</a>
    <div class="kicker mono">
      <a href={localizeUrl("/work/#featured", lang)}>{tr("work.featured")}</a>
      {
        data.categories.map((c) => (
          <>
            {" · "}
            <a href={localizeUrl(`/work/#${encodeURIComponent(c)}`, lang)}>{c}</a>
          </>
        ))
      }
    </div>
    <h1>{data.title}</h1>
    <p class="summary">{data.summary}</p>
    <div class="meta mono">
      {
        data.role &&
          data.role.split(" / ").map((r, i) => (
            <>
              {i > 0 && " / "}
              <a href={localizeUrl(`/work/#${encodeURIComponent(r.toLowerCase())}`, lang)}>
                {r.toUpperCase()}
              </a>
            </>
          ))
      }
      {
        data.location &&
          data.location.split(",").map((l) => (
            <>
              {" · "}
              <a href={localizeUrl(`/work/#${encodeURIComponent(l.trim().toLowerCase())}`, lang)}>
                {l.trim().toUpperCase()}
              </a>
            </>
          ))
      }
      {
        years && (
          <>
            {" · "}
            <a href={localizeUrl(`/work/#${data.date!.getFullYear()}`, lang)}>{years}</a>
          </>
        )
      }
      {
        data.url && (
          <span>
            {" · "}
            <a href={data.url} target="_blank" rel="noopener noreferrer">
              {tr("work.visit")}
            </a>
          </span>
        )
      }
    </div>
    {
      data.image && (
        <img
          class:list={["cover", data.imageFit === "contain" && "contain"]}
          src={data.image}
          alt={data.imageAlt ?? data.title}
        />
      )
    }
    <div class="prose">
      <Content />
    </div>
  </article>
</SiteLayout>

<style>
  .mono { font-family: var(--font-mono); }
  .container { max-width: 720px; margin: 0 auto; padding: 48px 24px 96px; }
  .back {
    display: inline-block;
    font-size: 11.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 32px;
  }
  .back:hover { color: var(--primary); text-decoration: none; }
  .kicker {
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 10px;
  }
  h1 {
    font-size: clamp(1.9rem, 5vw, 2.8rem);
    font-weight: 300;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 16px;
  }
  .summary { color: var(--muted); font-size: 1.15rem; max-width: 56ch; }
  .meta { font-size: 11px; color: var(--dim); letter-spacing: 0.08em; margin: 14px 0 32px; }
  .meta a, .kicker a { color: inherit; border-bottom: 1px dotted var(--dim); }
  .meta a:hover, .kicker a:hover { color: var(--primary); border-bottom-color: var(--primary); text-decoration: none; }
  .kicker a { color: var(--primary); border-bottom-color: transparent; }
  .cover {
    width: 100%;
    border-radius: var(--radius-card);
    border: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .cover.contain {
    /* logos are often dark-on-transparent — light paper in both themes */
    background: #f5f3ed;
    object-fit: contain;
    padding: 32px;
    max-height: 320px;
  }
  .prose :global(p) { font-size: 1.02rem; line-height: 1.65; margin-bottom: 1.2em; }
  .prose :global(h2),
  .prose :global(h3) { margin: 1.5em 0 0.5em; font-weight: 400; }
  .prose :global(ul),
  .prose :global(ol) { padding-left: 1.4em; margin-bottom: 1.2em; line-height: 1.65; }
</style>
