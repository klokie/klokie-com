---
import BaseLayout from "@klokie/theme/layouts/BaseLayout.astro";
import SiteHeader from "@klokie/theme/components/SiteHeader.astro";
import SiteFooter from "@klokie/theme/components/SiteFooter.astro";
import Analytics from "@klokie/theme/components/Analytics.astro";
import "@klokie/theme/tokens/klokie.css";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { siteConfig } from "@/site/config";
import { localePaths, localizeUrl, defaultLocale, type Locale } from "@/i18n";
import { t } from "@/i18n/ui";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: object | object[];
  lang?: Locale;
  /**
   * false = this non-default-locale page renders untranslated (default-locale)
   * fallback content. Its canonical then points at the default-locale page and
   * hreflang alternates are omitted (duplicates canonicalize; hreflang is only
   * for real translations).
   */
  translated?: boolean;
}
const {
  title,
  description,
  ogImage,
  ogType = "website",
  jsonLd,
  lang = defaultLocale,
  translated = true,
} = Astro.props;
const tr = t(lang);
const fullTitle = title ? `${title} — ${siteConfig.title}` : siteConfig.title;
const alternates = localePaths(Astro.url.pathname);
const isFallback = lang !== defaultLocale && !translated;
const canonical = new URL(
  isFallback ? alternates[defaultLocale] : Astro.url.pathname,
  siteConfig.url,
).href;

// default site-wide og:image (1200×630) so shares never look empty
const isDefaultOg = !ogImage;
const ogImageAbs = new URL(ogImage ?? "/og.png", siteConfig.url).href;
const ogLocale = lang === "sv" ? "sv_SE" : "en_US";

// serialize JSON-LD so content can't break out of the <script> tag
const jsonLdSafe = jsonLd
  ? JSON.stringify(jsonLd)
      .replace(/</g, "\\u003c")
      .replace(/>/g, "\\u003e")
      .replace(/&/g, "\\u0026")
  : null;

const nav = [
  { label: tr("nav.work"), href: localizeUrl("/work", lang) },
  { label: tr("nav.articles"), href: localizeUrl("/articles", lang) },
  { label: tr("nav.music"), href: localizeUrl("/music", lang) },
  { label: tr("nav.about"), href: localizeUrl("/about", lang) },
  { label: tr("nav.contact"), href: localizeUrl("/contact", lang) },
];
---

<BaseLayout
  title={fullTitle}
  description={description ?? tr("site.description")}
  preset={siteConfig.preset}
  ogImage={ogImageAbs}
  lang={lang}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content={ogLocale} />
    {
      isDefaultOg && (
        <>
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta property="og:image:alt" content="KLOKIE. — Daniel “Klokie” Grossfeld, senior web architect, Stockholm" />
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description ?? tr("site.description")} />
    <meta name="twitter:image" content={ogImageAbs} />
    {jsonLdSafe && <script type="application/ld+json" is:inline set:html={jsonLdSafe} />}
    <Analytics
      posthog={{
        key: import.meta.env.PUBLIC_POSTHOG_KEY,
        host: import.meta.env.PUBLIC_POSTHOG_HOST,
      }}
      sentry={{
        dsn: import.meta.env.PUBLIC_SENTRY_DSN,
        environment: import.meta.env.PUBLIC_SENTRY_ENV,
      }}
    />
    {
      !isFallback &&
        Object.entries(alternates).map(([l, path]) => (
          <link rel="alternate" hreflang={l} href={new URL(path, siteConfig.url).href} />
        ))
    }
    {
      !isFallback && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={new URL(alternates[defaultLocale], siteConfig.url).href}
        />
      )
    }
    <script is:inline>
      // apply saved theme before paint; default is dark (:root)
      if (localStorage.getItem("theme") === "light")
        document.documentElement.dataset.theme = "light";
    </script>
  </Fragment>

  <div class="rainbow-stripe"></div>
  <SiteHeader
    title={siteConfig.title}
    monogram={siteConfig.monogram}
    nav={nav}
    homeHref={localizeUrl("/", lang)}
  >
    <Fragment slot="nav-end">
      <LanguageSwitcher lang={lang} pathname={Astro.url.pathname} />
      <button id="theme-toggle" aria-label="Toggle color theme">
        dark ⁄ light
      </button>
    </Fragment>
  </SiteHeader>
  <main>
    <slot />
  </main>
  <div class="rainbow-stripe"></div>
  <SiteFooter
    copyrightName={siteConfig.copyrightName}
    social={siteConfig.social}
    credit={{ label: "Made with ❤️ by Klokie.com", href: "https://klokie.com" }}
  />
</BaseLayout>

<style is:global>
  /* sticky footer: short pages keep the footer at the viewport bottom */
  body {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }
  body > main {
    flex: 1;
  }
  /* compact footer: the rainbow stripe is the separator, so drop the theme
     footer's own border + big margins */
  .site-footer {
    margin-top: 0 !important;
    padding: 18px 24px 22px !important;
    border-top: none !important;
  }
</style>

<style>
  #theme-toggle {
    cursor: pointer;
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 12px;
    margin-left: 16px;
  }
  #theme-toggle:hover {
    color: var(--primary);
    border-color: var(--primary);
  }
</style>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const root = document.documentElement;
    const next = root.dataset.theme === "light" ? "dark" : "light";
    if (next === "light") root.dataset.theme = "light";
    else delete root.dataset.theme;
    localStorage.setItem("theme", next);
  });
</script>
